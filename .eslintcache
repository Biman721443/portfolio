master\\src\\components\\section\\Works.js",["49","50"],"import React from 'react'\nimport Project from '../layouts/Project'\nimport { projects, miscellaneous, section3Title, section4Title } from '../../profile'\n\nconst Works = () => {\n    return (\n        <>\n            <div data-aos=\"zoom-in-up\" data-aos-once=\"true\" className=\"third\">\n                <>\n                    <div className=\"pp-head-line mx-auto text-center\">\n                        <h1 id=\"Projects\" className=\"red-line pp-head\">{section3Title}</h1>\n                    </div>\n                </>\n                <div className=\"row\">\n                {projects && projects.map((x) => \n                <Project key={x.id} id={x.id} url={x.url} name={x.name} skills={x.skills} descriptions={x.descriptions} github={x.github} deploy={x.deploy} deployurl={x.deployurl}/>\n                )}\n                </div>\n            </div>\n\n            {/* <div className=\"third\">\n                <>\n                    <div className=\"pp-head-line mx-auto text-center\">\n                        <h1 id=\"Projects\" className=\"red-line pp-head\">{section4Title}</h1>\n                    </div>\n                </>\n                <div className=\"row\">\n                    {miscellaneous && miscellaneous.map((x) => \n                    <Project key={x.id} id={x.id} url={x.url} name={x.name} />\n                    )}\n                </div>\n            </div> */}\n        </>\n    )\n}\n\nexport default Works\n","C:\\Users\\Biman Gharai\\OneDrive\\Desktop\\Rct-211\\portfolio\\portfolio-master\\src\\components\\section\\Contact.js",[],"C:\\Users\\Biman Gharai\\OneDrive\\Desktop\\Rct-211\\portfolio\\portfolio-master\\src\\components\\section\\About.js",["51"],"import React from 'react'\nimport Skills from '../layouts/Skills'\nimport { about, skillsBar, section2title,social} from '../../profile'\n\nconst About = () => {\n    return (\n        <div id=\"about\" className=\"effect2\">\n            <div data-aos=\"zoom-in-up\" data-aos-once=\"true\" className=\"row\">\n            <div className=\"col-12 d-none d-md-block offset-md-1 col-md-4 Photo\" id=\"not-dark2\"></div>\n            <div className=\"col-12 offset-md-1 col-md-6 about\">\n                <div className=\"About-title-box\">\n                <h1 id=\"About\" className=\"red-line\">{section2title}  {social.resume && <a title=\"Download Resume\" href={\"#\"} download><i className=\"\"></i></a>}</h1>\n                \n                {/* fas fa-download */}\n                </div>\n                <p className=\"lead about-text\">\n                    {about.paragraph}  \n                   \n                </p>\n            </div>\n            </div>\n            <div id=\"Skills\"> \n                <div className=\"row d-flex justify-content-center skills\">\n                    {skillsBar.map((x) => \n                        <Skills key={x.name} faClass={x.faClass} svg={x.svg} label={x.name}/>\n                    )}̀\n                </div> \n            </div>\n        </div>\n    )\n}\n\nexport default About\n","C:\\Users\\Biman Gharai\\OneDrive\\Desktop\\Rct-211\\portfolio\\portfolio-master\\src\\components\\layouts\\HeaderButton.js",[],"C:\\Users\\Biman Gharai\\OneDrive\\Desktop\\Rct-211\\portfolio\\portfolio-master\\src\\components\\layouts\\Skills.js",[],"C:\\Users\\Biman Gharai\\OneDrive\\Desktop\\Rct-211\\portfolio\\portfolio-master\\src\\components\\layouts\\Project.js",["52","53"],"import React from 'react'\n\nconst Project = ({id, name, url, skills,descriptions,github,deploy,deployurl}) => {\n    return (\n        <div data-aos=\"fade-up\" className=\" col-12 col-lg-12 project-card\">\n            <div className=\"image-project\">\n                <div className={`img-pro ${id}`}></div>\n            </div>\n            <div className=\"project_details_holder\">\n                <div className=\"project_name_holder\">\n\n                    <a title={url} className=\"project-name\" rel=\"noopener noreferrer\" target=\"_blank\" href={url}><h2>{name}</h2></a>\n                \n    \n                </div>\n                <div className=\"project_decs_holder\">\n                   {descriptions && <h4>{descriptions}</h4>}\n                   { skills && <h3>{skills.map(skill => skill)}</h3> }\n                   <div className=\"deploy\">\n                   <a href={url} target=\"_blank\"> \n                   <i className={github}/>\n                   <div className=\"linkText\">Github</div>\n                   </a>\n                   <a href={deployurl} target=\"_blank\"> <i className={deploy}/>\n                   <div className=\"linkText\">web site</div>\n                   </a>\n                   </div>\n                </div>\n            </div>\n            \n        </div>\n    )\n}\n\nexport default Project\n",{"ruleId":"54","severity":1,"message":"55","line":3,"column":20,"nodeType":"56","messageId":"57","endLine":3,"endColumn":33},{"ruleId":"54","severity":1,"message":"58","line":3,"column":50,"nodeType":"56","messageId":"57","endLine":3,"endColumn":63},{"ruleId":"59","severity":1,"message":"60","line":12,"column":88,"nodeType":"61","endLine":12,"endColumn":135},{"ruleId":"62","severity":1,"message":"63","line":20,"column":20,"nodeType":"61","messageId":"64","endLine":20,"endColumn":50,"fix":"65"},{"ruleId":"62","severity":1,"message":"63","line":24,"column":20,"nodeType":"61","messageId":"64","endLine":24,"endColumn":56,"fix":"66"},"no-unused-vars","'miscellaneous' is defined but never used.","Identifier","unusedVar","'section4Title' is defined but never used.","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","noTargetBlank",{"range":"67","text":"68"},{"range":"69","text":"68"},[883,883]," rel=\"noreferrer\"",[1065,1065]]